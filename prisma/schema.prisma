// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Match {
  id                  String       @id @default(uuid())
  externalApiId       String?      @unique
  stage               String       // Enum representation: GROUP_STAGE, ROUND_OF_32, etc.
  groupName           String?      // Optional, e.g. "Grupo A", "Grupo B"
  homeTeam            String
  awayTeam            String
  kickoffAt           DateTime?
  status              String       @default("SCHEDULED") // Enum: SCHEDULED, IN_PROGRESS, FINISHED, MANUAL_PROJECTION
  actualHomeScore     Int?
  actualAwayScore     Int?
  actualHomePenalties Int?
  actualAwayPenalties Int?
  actualWinner        String?      // Name of the team that won (useful for draws in final stage)
  resultSource        String       @default("NONE") // Enum: NONE, API, MANUAL_REAL, MANUAL_SIMULATION
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  
  predictions         Prediction[]
  scores              Score[]
}

model User {
  id                 String       @id @default(uuid())
  username           String
  normalizedUsername String       @unique
  passwordHash       String
  role               String       @default("USER") // ADMIN or USER
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  predictions        Prediction[]
  scores             Score[]
  sessions           Session[]
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
}

model AuthAttempt {
  id          String   @id @default(uuid())
  ipHash      String
  username    String?  // normalizado
  count       Int      @default(1)
  lastAttempt DateTime @default(now())
}

model Prediction {
  id                     String   @id @default(uuid())
  matchId                String
  match                  Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  predictedHomeScore     Int?
  predictedAwayScore     Int?
  predictedHomePenalties Int?
  predictedAwayPenalties Int?
  predictedWinner        String?  // Name of the predicted winner (for final stage draws)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Score {
  id           String   @id @default(uuid())
  matchId      String
  match        Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  points       Int
  reason       String
  calculatedAt DateTime @default(now())

  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SyncLog {
  id           String    @id @default(uuid())
  provider     String    // e.g. "API-Football"
  syncType     String    // e.g. "FULL", "DAILY", "LIVE", "MANUAL"
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String    // e.g. "SUCCESS", "FAILED", "IN_PROGRESS"
  createdCount Int       @default(0)
  updatedCount Int       @default(0)
  skippedCount Int       @default(0)
  errorCount   Int       @default(0)
  message      String?
}
